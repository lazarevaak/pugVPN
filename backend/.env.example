# API
PORT=8080
PUGVPN_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/pugvpn?sslmode=disable
PUGVPN_DB_SSLMODE=disable

PUGVPN_DEMO_USER_ID=user_demo
PUGVPN_DEMO_EMAIL=demo@pugvpn.app
PUGVPN_DEMO_PASSWORD=demo1234
PUGVPN_PASSWORD_HASH_ITERATIONS=150000
PUGVPN_PASSWORD_SALT=pugvpn-dev-salt

# Optional local Postgres vars if you prefer discrete settings
PUGVPN_DB_HOST=127.0.0.1
PUGVPN_DB_PORT=5432
PUGVPN_DB_NAME=pugvpn
PUGVPN_DB_USER=postgres
PUGVPN_DB_PASSWORD=postgres

# Docker Compose Postgres container
POSTGRES_PORT=5432
POSTGRES_DB=pugvpn
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# VPN server published to clients
PUGVPN_SERVER_ID=srv_fi_1
PUGVPN_SERVER_NAME=Finland_1
PUGVPN_SERVER_LOCATION=FI
PUGVPN_SERVER_ENDPOINT=CHANGE_ME_SERVER_ENDPOINT:443
PUGVPN_SERVER_PUBLIC_KEY=CHANGE_ME_SERVER_PUBLIC_KEY
PUGVPN_SERVER_SUBNET=10.77.77
PUGVPN_SERVER_DNS=1.1.1.1,8.8.8.8
PUGVPN_SERVER_MTU=1200

# AmneziaWG obfuscation parameters
PUGVPN_AWG_JC=4
PUGVPN_AWG_JMIN=64
PUGVPN_AWG_JMAX=512
PUGVPN_AWG_S1=32
PUGVPN_AWG_S2=40
PUGVPN_AWG_S3=24
PUGVPN_AWG_S4=16
PUGVPN_AWG_H1=11111111
PUGVPN_AWG_H2=22222222
PUGVPN_AWG_H3=33333333
PUGVPN_AWG_H4=44444444

# Peer provisioning:
# off  -> only return config to client
# local -> run provisioning commands inside this container
# ssh  -> connect to VPN host and append/restart interface
PUGVPN_PROVISION_MODE=off
PUGVPN_PROVISION_INTERFACE=awg0

# Needed only for PUGVPN_PROVISION_MODE=ssh
PUGVPN_PROVISION_SSH_HOST=CHANGE_ME_SERVER_HOST
PUGVPN_PROVISION_SSH_USER=root
PUGVPN_PROVISION_SSH_PORT=22
PUGVPN_PROVISION_SSH_KEY_PATH=/root/.ssh/pugvpn_waicore

# Security and preflight
PUGVPN_AUTH_RATE_LIMIT_WINDOW_MINUTES=15
PUGVPN_AUTH_RATE_LIMIT_MAX_ATTEMPTS=8
PUGVPN_PREFLIGHT_TCP_TIMEOUT_MS=3000

# Optional secrets manager integration
# PUGVPN_SECRETS_COMMAND=op read "op://vault/item/secrets_json"
# PUGVPN_SECRETS_JSON={"server_endpoint":"vpn.example.com:443","server_public_key":"..."}
